{
  "name": "quikleaf",
  "version": "1.0.1",

  "type": "module",
  "description": "A standalone, cross-platform desktop markdown editor with rich rendering and LLM chat integration",
  "author": "deftio <deftio@deftio.com>",
  "license": "BSD-2-Clause",
  "homepage": "https://github.com/deftio/quikleaf",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deftio/quikleaf.git"
  },
  "bugs": {
    "url": "https://github.com/deftio/quikleaf/issues"
  },
  "keywords": [
    "markdown",
    "editor",
    "desktop",
    "tauri",
    "quikdown",
    "llm",
    "ai",
    "mermaid",
    "latex",
    "geojson"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "setup": "node tools/check-deps.cjs",
    "tauri:dev": "node tools/check-deps.cjs && tauri dev",
    "tauri:build": "node tools/check-deps.cjs && tauri build",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev:e2e": "vite --config vite.config.e2e.ts --port 1421",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "feature": "bash ./tools/feature.sh",
    "release": "bash ./tools/release.sh",
    "release:no-playwright": "SKIP_PLAYWRIGHT=1 bash ./tools/release.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.11.2",
    "@vitest/coverage-v8": "^4.1.8",
    "happy-dom": "^20.10.2",
    "jsdom": "^27.0.1",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "quikdown": "^1.2.17"
  }
}
